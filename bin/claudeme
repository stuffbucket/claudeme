#!/bin/bash
#
# claudeme - Claude Code launcher and setup tool for macOS
#
# Usage:
#   claudeme setup    - Create ~/Claude folder with orange tag
#   claudeme launch   - Launch Claude Code in ~/Claude
#   claudeme [path]   - Launch Claude Code in the specified directory
#   claudeme here     - Launch Claude Code in current directory
#

set -euo pipefail

CLAUDE_HOME="${HOME}/Claude"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

info() { echo -e "${GREEN}✓${NC} $1"; }
warn() { echo -e "${YELLOW}!${NC} $1"; }
error() { echo -e "${RED}✗${NC} $1" >&2; }

# Check if claude command exists
check_claude_installed() {
    if ! command -v claude &> /dev/null; then
        error "Claude Code CLI not found. Please install it first:"
        echo "  npm install -g @anthropic-ai/claude-code"
        exit 1
    fi
}

# Create ~/Claude folder
create_claude_folder() {
    if [[ -d "$CLAUDE_HOME" ]]; then
        info "Folder already exists: $CLAUDE_HOME"
    else
        mkdir -p "$CLAUDE_HOME"
        info "Created folder: $CLAUDE_HOME"
    fi
}

# Tag folder orange using macOS extended attributes
tag_folder_orange() {
    local folder="$1"
    
    # Use osascript to set Finder label (most reliable method)
    if osascript -e "
        tell application \"Finder\"
            set theFolder to POSIX file \"$folder\" as alias
            set label index of theFolder to 1
        end tell
    " 2>/dev/null; then
        info "Tagged folder orange"
    else
        warn "Could not set orange tag (non-critical)"
    fi
}

# Check if a directory is safe (not home, root, or other sensitive paths)
is_safe_directory() {
    local dir="$1"
    local resolved_dir
    
    # Resolve to absolute path
    resolved_dir="$(cd "$dir" 2>/dev/null && pwd)" || return 1
    
    # List of dangerous directories that should never be trusted
    local dangerous_paths=(
        "$HOME"
        "/"
        "/Users"
        "/System"
        "/Applications"
        "/Library"
        "/private"
        "/tmp"
        "/var"
    )
    
    for dangerous in "${dangerous_paths[@]}"; do
        if [[ "$resolved_dir" == "$dangerous" ]]; then
            return 1
        fi
    done
    
    return 0
}

# Launch Claude Code in a directory
launch_claude() {
    local target_dir="$1"
    
    check_claude_installed
    
    # Validate directory exists
    if [[ ! -d "$target_dir" ]]; then
        error "Directory does not exist: $target_dir"
        exit 1
    fi
    
    # Get absolute path
    target_dir="$(cd "$target_dir" && pwd)"
    
    # Safety check
    if ! is_safe_directory "$target_dir"; then
        error "Refusing to launch Claude Code in '$target_dir'"
        echo "    This directory is too broad. Use a project folder like ~/Claude/myproject"
        exit 1
    fi
    
    info "Launching Claude Code in: $target_dir"
    cd "$target_dir"
    exec claude
}

# Run setup
run_setup() {
    echo "Setting up Claude Code environment..."
    echo
    
    # Check claude is installed first
    check_claude_installed
    
    # Create folder
    create_claude_folder
    
    # Tag it orange
    tag_folder_orange "$CLAUDE_HOME"
    
    echo
    info "Setup complete!"
    echo
    echo "Your Claude projects folder: ~/Claude"
    echo
    echo "Usage:"
    echo "  claudeme launch              # Open Claude in ~/Claude"
    echo "  claudeme ~/Claude/myproject  # Open Claude in a specific project"
    echo
    echo "Tip: For one-click Finder integration, install OpenInTerminal-Lite:"
    echo "  brew install --cask openinterminal-lite"
    echo "  Then drag it to your Finder toolbar and type 'claude' when it opens."
    echo
}

# Show usage
show_usage() {
    cat << 'USAGE'
claudeme - Claude Code launcher and setup tool

Usage:
  claudeme setup      Set up ~/Claude folder with orange Finder tag
  claudeme launch     Launch Claude Code in ~/Claude
  claudeme here       Launch Claude Code in current directory
  claudeme <path>     Launch Claude Code in the specified directory
  claudeme --help     Show this help message

Examples:
  claudeme setup                    # One-time setup
  claudeme ~/Claude/my-project      # Launch in specific project
  claudeme .                        # Launch in current directory

For one-click Finder integration:
  brew install --cask openinterminal-lite
  Drag to Finder toolbar, then type 'claude' when Terminal opens.

USAGE
}

# Main
main() {
    local cmd="${1:-}"
    
    case "$cmd" in
        setup|--setup|-s)
            run_setup
            ;;
        launch|--launch|-l)
            launch_claude "$CLAUDE_HOME"
            ;;
        here|.)
            launch_claude "$(pwd)"
            ;;
        --help|-h|help)
            show_usage
            ;;
        "")
            show_usage
            ;;
        *)
            # Assume it's a path
            if [[ -d "$cmd" ]]; then
                launch_claude "$cmd"
            else
                error "Unknown command or invalid path: $cmd"
                echo
                show_usage
                exit 1
            fi
            ;;
    esac
}

main "$@"
