#!/bin/sh
# Run checks before push
set -e

echo "Running pre-push checks..."

# Check shell script syntax
echo "→ Checking syntax..."
bash -n bin/claudeme

# Run shellcheck if available
if command -v shellcheck >/dev/null 2>&1; then
  echo "→ Running shellcheck..."
  shellcheck bin/claudeme
fi

# Verify workflow plists
echo "→ Verifying workflows..."
plutil -lint share/claudeme/workflows/Open\ in\ Claude\ Code.workflow/Contents/Info.plist >/dev/null
plutil -lint share/claudeme/workflows/Open\ in\ Claude\ Code.workflow/Contents/document.wflow >/dev/null

echo "✓ All pre-push checks passed"
